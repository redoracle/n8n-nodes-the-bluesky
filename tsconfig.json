{
	"$schema": "https://json.schemastore.org/tsconfig",
	"compilerOptions": {
		"lib": ["es2019"],
		"baseUrl": ".",
		"module": "commonjs",
		"moduleResolution": "node",
		"noImplicitAny": true,
		"removeComments": true,
		"strictNullChecks": true,
		"strict": true,
		"preserveConstEnums": true,
		"resolveJsonModule": true,
		"declaration": true,
		"outDir": "./dist/",
		"target": "es2019",
		"sourceMap": true,
		"esModuleInterop": true,
		"allowSyntheticDefaultImports": true,
		"useUnknownInCatchVariables": false,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"types": [],
		// Standard @types packages from pnpm. Custom shims in ./types/ are loaded via
		// the include array above, not via typeRoots (typeRoots requires package subdirs).
		"typeRoots": ["./node_modules/@types"]
	},
	"include": [
		"types/**/*.d.ts",
		"credentials/**/*",
		"nodes/**/*",
		"nodes/**/*.json",
		"package.json",
		"__tests__/**/*",
		"src/**/*"
	],
	"exclude": ["node_modules", "dist", "types/n8n-workflow-shim.d.ts"]
}
