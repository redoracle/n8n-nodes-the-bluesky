				"mode": "runOnceForAllItems",
				"jsCode": "// Safe-mode compatibility workflow for Bluesky\n// Populate the handle/DID fields to improve coverage across read-only operations.\n// allowWriteOps: set true to run create/update steps (default: false).\n// allowDestructiveOps: set true to run delete steps (default: false).\n\nreturn [{ json: {\n  safeMode: true,\n  allowWriteOps: false,\n  allowDestructiveOps: false,\n  handle: 'example.bsky.social',\n  did: 'did:plc:example',\n  actors: 'example.bsky.social',\n  postText: `Safe compatibility post ${new Date().toISOString()}`,\n  searchQuery: 'n8n',\n  feedUri: 'at://did:plc:example/app.bsky.feed.generator/example',\n  postUri: '',\n  postCid: '',\n  postUris: '',\n  listUri: '',\n  uriPatterns: 'at://did:plc:example/app.bsky.feed.post/*',\n  lexiconUrl: 'https://bsky.social/xrpc/com.atproto.sync.getRepo',\n  syncDid: 'did:plc:example'\n}}];"
			}
		},
