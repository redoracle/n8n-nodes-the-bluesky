      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "const nodeNames = [\n  '02 Post Create',\n  '03 Feed Timeline',\n  '04 Feed Get Author Feed',\n  '05 Feed Get Post Thread',\n  '06 Feed Get Likes',\n  '07 Feed Get Reposted By',\n  '08 Feed Get Posts',\n  '09 Search Users',\n  '10 Search Posts',\n  '11 User Get Profile',\n  '12 User Get Profiles',\n  '13 User List Followers (Paged)',\n  '14 User List Follows (Paged)',\n  '15 Identity Resolve Handle',\n  '16 Identity Resolve DID',\n  '17 Identity Resolve Identity',\n  '18 Notification Get Unread Count',\n  '19 Notification List',\n  '20 Analytics Get Unread Count',\n  '21 Analytics List Notifications',\n  '22 Analytics Get Post Interactions',\n  '23 Lexicon Resolve Lexicon',\n  '24 Preferences Get Preferences',\n  '25 Label Query Labels',\n  '26 Sync Get Repo Status',\n  '27 Sync Get Latest Commit',\n  '28 Sync List Repos',\n  '28 Repo Upload Blob',\n  '29 Post Delete Post',\n  '29 Skip Delete Post'\n];\n\nconst allowEmptyPayloadNodes = new Set([\n  '06 Feed Get Likes',\n  '07 Feed Get Reposted By',\n  '19 Notification List',\n  '21 Analytics List Notifications',\n  '29 Skip Delete Post'\n]);\n\nconst softFailMessageRules = {\n  '23 Lexicon Resolve Lexicon': ['XRPCNotSupported'],\n  '26 Sync Get Repo Status': ['Could not find repo for DID'],\n  '27 Sync Get Latest Commit': ['Could not find repo for DID'],\n};\n\nfunction extractErrors(json, statusCode) {\n  const out = [];\n  if (json?.message) out.push(String(json.message));\n  if (json?.errorMessage) out.push(String(json.errorMessage));\n  if (json?.error) {\n    if (json.error.message) out.push(String(json.error.message));\n    else if (typeof json.error === 'string') out.push(json.error);\n    else out.push(JSON.stringify(json.error));\n  }\n  if (statusCode !== undefined && statusCode >= 400) out.push('HTTP ' + statusCode);\n  return out;\n}\n\nconst results = [];\nfor (const nodeName of nodeNames) {\n  let nodeItems;\n  try {\n    nodeItems = $items(nodeName, 0, 0);\n  } catch (e) {\n    const msg = String(e);\n    if (msg.includes(\"hasn't been executed\")) {\n      results.push({ test: nodeName, status: 'SKIPPED', itemCount: 0, errorCount: 0, errors: [], items: [] });\n    } else {\n      results.push({ test: nodeName, status: 'NOT_EXECUTED', itemCount: 0, errorCount: 1, errors: [msg], items: [] });\n    }\n    continue;\n  }\n\n  const itemResults = (nodeItems || []).map((item, index) => {\n    const json = item?.json ?? {};\n    const statusCode = typeof json.statusCode === 'number' ? json.statusCode : undefined;\n    const errorMessages = extractErrors(json, statusCode);\n    const isEmptyPayload = json && typeof json === 'object' && Object.keys(json).length === 0;\n\n    if (isEmptyPayload && !allowEmptyPayloadNodes.has(nodeName)) {\n      errorMessages.push('EMPTY_PAYLOAD');\n    }\n\n    if (errorMessages.length > 0) {\n      const softTerms = softFailMessageRules[nodeName] || [];\n      const isSoft = softTerms.length > 0 && errorMessages.every((m) => softTerms.some((term) => String(m).includes(term)));\n      return {\n        index,\n        status: isSoft ? 'PASS_SOFT_FAIL' : 'FAIL',\n        error: errorMessages.join(' | '),\n        keys: Object.keys(json).slice(0, 12),\n      };\n    }\n\n    if (isEmptyPayload && allowEmptyPayloadNodes.has(nodeName)) {\n      return { index, status: 'PASS_EMPTY_OK', error: null, keys: [] };\n    }\n\n    return {\n      index,\n      status: 'PASS',\n      error: null,\n      keys: Object.keys(json).slice(0, 12),\n    };\n  });\n\n  const errors = itemResults.filter((r) => r.status === 'FAIL').map((r) => r.error).filter(Boolean);\n  const passLike = new Set(['PASS', 'PASS_EMPTY_OK', 'PASS_SOFT_FAIL']);\n  const status = errors.length > 0 ? 'FAIL' : (itemResults.some((r) => passLike.has(r.status)) ? 'PASS' : 'SKIPPED');\n\n  results.push({\n    test: nodeName,\n    status,\n    itemCount: itemResults.length,\n    errorCount: errors.length,\n    errors,\n    items: itemResults,\n  });\n}\n\nconst passed = results.filter((r) => r.status === 'PASS').length;\nconst failed = results.filter((r) => r.status === 'FAIL').length;\nconst skipped = results.filter((r) => r.status === 'SKIPPED').length;\nconst notExecuted = results.filter((r) => r.status === 'NOT_EXECUTED').length;\nconst totalErrors = results.reduce((sum, r) => sum + (r.errorCount || 0), 0);\nconst totalItems = results.reduce((sum, r) => sum + (r.itemCount || 0), 0);\n\nreturn [{\n  json: {\n    summary: {\n      totalTests: results.length,\n      passed,\n      failed,\n      skipped,\n      notExecuted,\n      totalErrors,\n      totalItems,\n      successRate: results.length ? Number(((passed / results.length) * 100).toFixed(2)) : 0,\n      timestamp: new Date().toISOString(),\n    },\n    results,\n  },\n}];"
      }
    },
